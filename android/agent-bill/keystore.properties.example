# Copy to keystore.properties (gitignored) and fill in.
# Generate the keystore with:
#   keytool -genkeypair -v \
#     -keystore agentbill-release.jks \
#     -alias agentbill \
#     -keyalg RSA -keysize 2048 -validity 10000 \
#     -storepass <choose> -keypass <choose> \
#     -dname "CN=Igor Ganapolsky, O=AgentBill, C=US"
storeFile=agentbill-release.jks
storePassword=<your store password>
keyAlias=agentbill
keyPassword=<your key password>
